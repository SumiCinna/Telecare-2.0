Options -Indexes

# Block direct access to includes folder
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block access to includes/ directory entirely
    RewriteRule ^includes/ - [F,L]

    # Only allow PHP files — block everything else
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{THE_REQUEST} \s.+\.(?!php)[a-z]+\s [NC]
    RewriteRule . - [F,L]
</IfModule>

# Prevent access to sensitive file types
<FilesMatch "\.(env|log|sql|bak|sh|config|ini|json|md|txt|xml|yml|yaml)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
