# ============================================================
# DATABASE CONFIGURATION
# ============================================================
DB_HOST=localhost
DB_USER=telejnvk_telecare
DB_PASSWORD=your_password_here
DB_NAME=telejnvk_telecare
DB_CHARSET=utf8mb4

# ============================================================
# GOOGLE OAUTH CREDENTIALS
# ============================================================
# IMPORTANT: Add your own credentials from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI_LOGIN=https://telecareai.site/auth/google-callback.php
GOOGLE_REDIRECT_URI_REGISTER=https://telecareai.site/auth/google-register-callback.php

# ============================================================
# PAYMONGO PAYMENT API CREDENTIALS
# ============================================================
# IMPORTANT: Use ONLY the secret key for backend operations
PAYMONGO_SECRET_KEY=your_paymongo_secret_key_here

# ============================================================
# OCR.SPACE API
# ============================================================
OCR_SPACE_API_KEY=your_ocr_space_api_key_here

# ============================================================
# GROQ AI API
# ============================================================
# IMPORTANT: Add your key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ============================================================
# APPLICATION SETTINGS
# ============================================================
APP_ENV=production
APP_DEBUG=false
APP_URL=https://telecareai.site
