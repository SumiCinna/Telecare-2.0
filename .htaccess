Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Block access to hidden files (.env, .git, etc.)
    RewriteRule (^|/)\.(?!well-known) - [F,L]
</IfModule>

# Explicitly block .env file
<Files ".env">
    Order Allow,Deny
    Deny from all
</Files>

# Block sensitive files
<FilesMatch "\.(env|log|sql|bak|sh|config|ini|json|md|txt|xml|yml|yaml|pem|key|crt|htpasswd)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Block access to database config
<Files "config.php">
    Order Allow,Deny
    Deny from all
</Files>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=self, camera=self"
</IfModule>

# Disable server signature
ServerSignature Off
